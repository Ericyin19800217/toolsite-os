---
import { DimensionalWeightCalculator } from "../components/DimensionalWeightCalculator";
import FormulaSourceNote from "../components/FormulaSourceNote.astro";
import ToolLayout from "../components/ToolLayout.astro";
import { getFormulaByCarrier } from "../content/formulaSources";

const fedexFormula = getFormulaByCarrier("fedex");
---

<ToolLayout
  title="Dimensional Weight Calculator for UPS, FedEx, USPS &amp; DHL"
  description="Calculate dimensional weight and billable weight for UPS, FedEx, USPS, DHL, and custom DIM factors."
>
  <section class="grid gap-4 pb-6 border-b border-[#e2e8f0]">
    <p class="section-label">Free multi-carrier tool</p>
    <h1 class="text-[36px] md:text-[48px] font-bold leading-[1.1] tracking-tight text-[#0f172a] max-w-3xl">
      Dimensional Weight Calculator
    </h1>
    <p class="max-w-2xl text-[15px] text-[#64748b] leading-relaxed">
      Estimate billable weight for UPS, FedEx, USPS, DHL, or a custom DIM divisor
      before you buy a label or quote a shipment.
    </p>
    <div class="flex flex-wrap gap-1.5">
      {["UPS","FedEx","USPS","DHL","Custom"].map((c) => (
        <span class="badge badge-neutral">{c}</span>
      ))}
    </div>
  </section>

  <DimensionalWeightCalculator client:visible defaultCarrier="fedex" />

  <FormulaSourceNote formula={fedexFormula} />

  <section id="formula" class="grid gap-3 pt-6">
    <h2 class="text-[24px] font-bold tracking-tight text-[#0f172a]">What is dimensional weight?</h2>
    <p class="text-[14px] text-[#64748b] leading-relaxed max-w-3xl">
      Dimensional weight (DIM weight) is a pricing weight based on how much space a
      package occupies. Carriers compare it with the actual scale weight and charge
      whichever is higher.
    </p>
    <p class="font-mono text-[14px] text-[#0f172a] bg-[#f8fafc] border border-[#e2e8f0] rounded-[4px] p-4 inline-block w-fit">
      DIM weight = L &times; W &times; H / divisor
    </p>
  </section>

  <section class="grid gap-3 pt-6 border-t border-[#e2e8f0]">
    <h2 class="text-[24px] font-bold tracking-tight text-[#0f172a]">Standard divisors</h2>
    <p class="text-[14px] text-[#64748b] leading-relaxed max-w-3xl">
      FedEx and UPS commonly use divisor <strong class="text-[#0f172a]">139</strong> for daily-rate shippers.
      USPS currently uses <strong class="text-[#0f172a]">166</strong>, changing to 139 on July 12, 2026.
      DHL Express uses <strong class="text-[#0f172a]">5000</strong> cm&sup3;/kg for international volumetric weight.
    </p>
  </section>

  <section id="disclaimer" class="grid gap-3 pt-6 border-t border-[#e2e8f0]">
    <h2 class="text-[24px] font-bold tracking-tight text-[#0f172a]">Disclaimer</h2>
    <p class="text-[14px] text-[#64748b] leading-relaxed max-w-3xl">
      This calculator provides estimates for planning and comparison only. Carrier
      rules, rounding, surcharges, and contract rates can change. Always confirm
      the final billable weight with your carrier before purchasing postage.
    </p>
  </section>
</ToolLayout>
