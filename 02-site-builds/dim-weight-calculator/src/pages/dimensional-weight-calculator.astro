---
import { DimensionalWeightCalculator } from "../components/DimensionalWeightCalculator";
import FormulaSourceNote from "../components/FormulaSourceNote.astro";
import ToolLayout from "../components/ToolLayout.astro";
import { getFormulaByCarrier } from "../content/formulaSources";

const fedexFormula = getFormulaByCarrier("fedex");
---

<ToolLayout
  title="Dimensional Weight Calculator for UPS, FedEx, USPS & DHL"
  description="Calculate dimensional weight and billable weight for UPS, FedEx, USPS, DHL, and custom DIM factors. Supports inches/lbs and cm/kg."
>
  <section class="grid gap-5 border-b border-slate-200 pb-6 md:grid-cols-[minmax(0,1fr)_340px] md:items-end">
    <div class="grid gap-4">
      <p class="text-sm font-semibold text-teal-700">
        Free shipping calculator
      </p>
      <h1 class="max-w-3xl text-4xl font-semibold text-slate-950">
        Dimensional Weight Calculator
      </h1>
      <p class="max-w-2xl text-base leading-7 text-slate-600">
        Estimate billable weight for UPS, FedEx, USPS, DHL, or a custom DIM
        divisor before you buy a label or quote a shipment.
      </p>
      <div class="flex flex-wrap gap-2 text-sm font-medium text-slate-600">
        <span class="rounded-md bg-slate-100 px-3 py-1.5">UPS</span>
        <span class="rounded-md bg-slate-100 px-3 py-1.5">FedEx</span>
        <span class="rounded-md bg-slate-100 px-3 py-1.5">USPS</span>
        <span class="rounded-md bg-slate-100 px-3 py-1.5">DHL</span>
        <span class="rounded-md bg-slate-100 px-3 py-1.5">Custom divisor</span>
      </div>
    </div>

    <dl class="grid gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm">
      <div class="flex items-center justify-between gap-4">
        <dt class="text-slate-500">Default formula</dt>
        <dd class="font-semibold text-slate-950">FedEx / 139</dd>
      </div>
      <div class="flex items-center justify-between gap-4 border-t border-slate-200 pt-3">
        <dt class="text-slate-500">Output</dt>
        <dd class="font-semibold text-slate-950">Billable weight</dd>
      </div>
      <div class="flex items-center justify-between gap-4 border-t border-slate-200 pt-3">
        <dt class="text-slate-500">Use case</dt>
        <dd class="font-semibold text-slate-950">Label planning</dd>
      </div>
    </dl>
  </section>

  <DimensionalWeightCalculator client:visible defaultCarrier="fedex" />

  <FormulaSourceNote formula={fedexFormula} />

  <section id="formula" class="grid gap-4 border-t border-slate-200 pt-8">
    <h2 class="text-2xl font-semibold text-slate-950">What dimensional weight is</h2>
    <p class="leading-7 text-slate-700">
      Dimensional weight, also called DIM weight or volumetric weight, is a
      pricing weight based on the amount of space a package occupies. Carriers
      compare dimensional weight with the package&apos;s actual scale weight and
      usually charge the higher billable weight.
    </p>
  </section>

  <section class="grid gap-4 border-t border-slate-200 pt-8">
    <h2 class="text-2xl font-semibold text-slate-950">Dimensional weight formula</h2>
    <p class="leading-7 text-slate-700">
      The common imperial formula is length x width x height divided by the DIM
      divisor. For example, FedEx and UPS package estimates commonly use a 139
      divisor, while USPS estimates commonly use 166 for eligible parcels. Metric
      DHL-style volumetric estimates often use centimeters divided by 5000.
    </p>
    <p class="rounded bg-slate-100 p-4 font-mono text-sm text-slate-900">
      Dimensional weight = length x width x height / DIM divisor
    </p>
  </section>

  <section id="disclaimer" class="grid gap-4 border-t border-slate-200 pt-8">
    <h2 class="text-2xl font-semibold text-slate-950">Disclaimer</h2>
    <p class="leading-7 text-slate-700">
      This calculator is an estimate for planning and comparison. Carrier rules,
      divisors, rounding, surcharges, service types, regions, contract rates, and
      freight programs can change. Confirm the final billable weight and charge
      with the carrier or shipping platform before purchasing postage.
    </p>
  </section>
</ToolLayout>
