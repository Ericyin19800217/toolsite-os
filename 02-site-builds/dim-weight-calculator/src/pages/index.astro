---
import ToolLayout from "../components/ToolLayout.astro";
---

<ToolLayout
  title="Dimensional Weight Calculator for UPS, FedEx, USPS &amp; DHL"
  description="Calculate dimensional weight and billable weight for UPS, FedEx, USPS, DHL, and custom DIM factors."
>
  <section class="grid gap-8 py-8 md:py-12">
    <!-- Hero -->
    <div class="grid gap-4">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#f59e0b]">
        Free Multi-Carrier Tool
      </p>
      <h1 class="display-font text-5xl md:text-7xl leading-none tracking-wide text-[#edf0f5] max-w-4xl">
        Dimensional Weight
        <span class="block text-[#f59e0b]">Calculator</span>
      </h1>
      <p class="max-w-xl text-sm leading-relaxed text-[#8899b4] mt-2">
        Estimate billable weight across UPS, FedEx, USPS, DHL and custom DIM
        divisors. Built for shippers, e-commerce sellers, and logistics
        professionals who need quick planning numbers before buying labels.
      </p>
    </div>

    <!-- Carrier quick-select -->
    <div class="grid gap-3">
      <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-[#566584]">
        Select Carrier
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/fedex-dimensional-weight-calculator/"
          class="group card-shipping px-5 py-4 hover:border-[#f59e0b] transition-colors min-w-[120px]"
        >
          <p class="text-[10px] tracking-[0.15em] uppercase text-[#566584] group-hover:text-[#f59e0b] transition-colors">FedEx</p>
          <p class="mt-1 font-mono text-lg font-semibold text-[#edf0f5]">/ 139</p>
          <p class="mt-0.5 text-[10px] text-[#566584]">Imperial</p>
        </a>
        <a
          href="/ups-dimensional-weight-calculator/"
          class="group card-shipping px-5 py-4 hover:border-[#f59e0b] transition-colors min-w-[120px]"
        >
          <p class="text-[10px] tracking-[0.15em] uppercase text-[#566584] group-hover:text-[#f59e0b] transition-colors">UPS</p>
          <p class="mt-1 font-mono text-lg font-semibold text-[#edf0f5]">/ 139</p>
          <p class="mt-0.5 text-[10px] text-[#566584]">Imperial</p>
        </a>
        <a
          href="/usps-dimensional-weight-calculator/"
          class="group card-shipping px-5 py-4 hover:border-[#f59e0b] transition-colors min-w-[120px]"
        >
          <p class="text-[10px] tracking-[0.15em] uppercase text-[#566584] group-hover:text-[#f59e0b] transition-colors">USPS</p>
          <p class="mt-1 font-mono text-lg font-semibold text-[#edf0f5]">/ 139</p>
          <p class="mt-0.5 text-[10px] text-[#566584]">Imperial</p>
        </a>
        <a
          href="/dhl-volumetric-weight-calculator/"
          class="group card-shipping px-5 py-4 hover:border-[#f59e0b] transition-colors min-w-[120px]"
        >
          <p class="text-[10px] tracking-[0.15em] uppercase text-[#566584] group-hover:text-[#f59e0b] transition-colors">DHL</p>
          <p class="mt-1 font-mono text-lg font-semibold text-[#edf0f5]">/ 5000</p>
          <p class="mt-0.5 text-[10px] text-[#566584]">Metric</p>
        </a>
        <a
          href="/dimensional-weight-calculator/"
          class="group card-shipping px-5 py-4 hover:border-[#f59e0b] transition-colors min-w-[120px] border-[#f59e0b]/30"
        >
          <p class="text-[10px] tracking-[0.15em] uppercase text-[#f59e0b]">All Carriers</p>
          <p class="mt-1 font-mono text-lg font-semibold text-[#fbbf24]">Compare</p>
          <p class="mt-0.5 text-[10px] text-[#566584]">Multi-select</p>
        </a>
      </div>
    </div>
  </section>
</ToolLayout>
