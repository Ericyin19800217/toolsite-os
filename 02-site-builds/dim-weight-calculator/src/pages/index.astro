---
import ToolLayout from "../components/ToolLayout.astro";
---

<ToolLayout
  title="Dimensional Weight Calculator for UPS, FedEx, USPS &amp; DHL"
  description="Calculate dimensional weight and billable weight for UPS, FedEx, USPS, DHL, and custom DIM factors."
>
  <section class="grid gap-8 py-8 md:py-12">
    <div class="grid gap-4">
      <p class="section-label">Free multi-carrier tool</p>
      <h1 class="text-[40px] md:text-[56px] font-bold leading-[1.08] tracking-tight text-[#0f172a] max-w-4xl">
        Dimensional Weight Calculator
      </h1>
      <p class="max-w-xl text-[15px] text-[#64748b] leading-relaxed">
        Estimate billable weight across UPS, FedEx, USPS, DHL, and custom DIM divisors.
        Built for shippers, e-commerce sellers, and logistics professionals.
      </p>
    </div>

    <div class="grid gap-3">
      <p class="section-label">Select a carrier</p>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {[
          { href: "/fedex-dimensional-weight-calculator/", carrier: "FedEx", div: "139", note: "U.S. &amp; International", accent: false },
          { href: "/ups-dimensional-weight-calculator/", carrier: "UPS", div: "139", note: "Daily Rates", sub: "Retail: 166", accent: false },
          { href: "/usps-dimensional-weight-calculator/", carrier: "USPS", div: "166", note: "&rarr; 139 Jul 12", sub: "", accent: true },
          { href: "/dhl-volumetric-weight-calculator/", carrier: "DHL", div: "5000", note: "cm&sup3;/kg &middot; Express", accent: false },
          { href: "/dimensional-weight-calculator/", carrier: "All Carriers", div: "Compare", note: "Full calculator", accent: false, primary: true },
        ].map((c) => (
          <a href={c.href} class={`card-flat p-4 hover:border-[#2563eb] transition-colors group ${c.primary ? "border-[#2563eb]/30 bg-[#eff6ff]" : ""}`}>
            <p class={`text-[11px] font-semibold tracking-[0.04em] uppercase ${c.primary ? "text-[#2563eb]" : "text-[#64748b]"} group-hover:text-[#2563eb] transition-colors`}>
              {c.carrier}
            </p>
            <p class={`mt-1.5 font-mono text-xl font-semibold ${c.primary ? "text-[#2563eb]" : "text-[#0f172a]"}`}>
              / {c.div}
            </p>
            <p class="mt-0.5 text-[12px] text-[#94a3b8]">{c.note}</p>
            {c.sub && <p class="text-[11px] text-[#2563eb] mt-0.5">{c.sub}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
</ToolLayout>
