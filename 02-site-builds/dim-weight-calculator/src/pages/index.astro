---
import ToolLayout from "../components/ToolLayout.astro";
---

<ToolLayout
  title="Dimensional Weight Calculator for UPS, FedEx, USPS &amp; DHL"
  description="Calculate dimensional weight and billable weight for UPS, FedEx, USPS, DHL, and custom DIM factors."
>
  <section class="grid gap-6 py-8">
    <h1 class="text-4xl font-semibold text-slate-950">
      Dimensional Weight Calculator
    </h1>
    <p class="max-w-2xl text-lg leading-7 text-slate-600">
      Free multi-carrier dimensional weight calculator. Estimate billable weight
      for UPS, FedEx, USPS, DHL, or a custom DIM divisor.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        class="rounded-md bg-slate-950 px-6 py-3 text-sm font-semibold text-white hover:bg-slate-800"
        href="/dimensional-weight-calculator/"
      >
        Open calculator
      </a>
      <a
        class="rounded-md border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-50"
        href="/fedex-dimensional-weight-calculator/"
      >
        FedEx
      </a>
      <a
        class="rounded-md border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-50"
        href="/ups-dimensional-weight-calculator/"
      >
        UPS
      </a>
      <a
        class="rounded-md border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-50"
        href="/usps-dimensional-weight-calculator/"
      >
        USPS
      </a>
      <a
        class="rounded-md border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-50"
        href="/dhl-volumetric-weight-calculator/"
      >
        DHL
      </a>
    </div>
  </section>
</ToolLayout>
