---
import type { CarrierFormula } from "../content/formulaSources";

interface Props {
  formula: CarrierFormula;
}

const { formula } = Astro.props;

const isLow = formula.confidence === "low";
const isHigh = formula.confidence === "high";

const cardBg = isLow ? "bg-[#0d1524]/50" : isHigh ? "bg-[#0d1a1a]" : "bg-[#0d1524]";
const accentBar = isLow ? "bg-[#334155]" : isHigh ? "bg-[#14b8a6]" : "bg-[#f59e0b]";
const badgeClass = isLow ? "badge-muted" : isHigh ? "badge-teal" : "badge-amber";
---

<aside
  id="sources"
  class={`card-shipping ${cardBg}`}
>
  <!-- Accent bar -->
  <div class={`h-0.5 w-full ${accentBar}`} aria-hidden="true"></div>

  <div class="p-5 grid gap-4">
    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="display-font text-xl tracking-wider text-[#edf0f5]">
          {formula.label} &mdash; Source Data
        </p>
        <p class="mt-1 text-xs text-[#8899b4] leading-relaxed">{formula.serviceScope}</p>
      </div>
      <span class={`text-[10px] font-semibold tracking-[0.15em] uppercase px-3 py-1 ${badgeClass}`}>
        {formula.confidence}
      </span>
    </div>

    <!-- Detail grid -->
    <dl class="grid sm:grid-cols-4 border-t border-[#1e3048]">
      <div class="border-b border-[#1e3048] p-3 sm:border-b-0 sm:border-r border-[#1e3048]">
        <dt class="text-[10px] font-semibold tracking-[0.15em] uppercase text-[#566584] mb-1">
          Formula
        </dt>
        <dd class="font-mono text-sm font-medium text-[#edf0f5]">{formula.formulaLabel}</dd>
      </div>
      <div class="border-b border-[#1e3048] p-3 sm:border-b-0 sm:border-r border-[#1e3048]">
        <dt class="text-[10px] font-semibold tracking-[0.15em] uppercase text-[#566584] mb-1">
          Confidence
        </dt>
        <dd class="font-mono text-sm font-medium text-[#8899b4]">{formula.confidence}</dd>
      </div>
      <div class="border-b border-[#1e3048] p-3 sm:border-b-0 sm:border-r border-[#1e3048]">
        <dt class="text-[10px] font-semibold tracking-[0.15em] uppercase text-[#566584] mb-1">
          Verified
        </dt>
        <dd class="font-mono text-sm text-[#8899b4]">
          {formula.sourceDate ?? "Needs source review before launch"}
        </dd>
      </div>
      <div class="p-3">
        <dt class="text-[10px] font-semibold tracking-[0.15em] uppercase text-[#566584] mb-1">
          Rounding
        </dt>
        <dd class="text-xs text-[#8899b4] leading-relaxed">{formula.roundingNote}</dd>
      </div>
    </dl>

    {
      formula.sourceUrl && (
        <a
          class="inline-flex items-center gap-2 w-fit px-4 py-2 text-xs font-semibold tracking-wider uppercase text-[#8899b4] border border-[#1e3048] hover:border-[#f59e0b] hover:text-[#f59e0b] transition-colors"
          href={formula.sourceUrl}
          rel="noreferrer"
          target="_blank"
        >
          View Source
          <span aria-hidden="true" class="font-mono">&rarr;</span>
        </a>
      )
    }
  </div>
</aside>
