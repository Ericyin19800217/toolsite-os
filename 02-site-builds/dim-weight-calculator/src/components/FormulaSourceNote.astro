---
import type { CarrierFormula } from "../content/formulaSources";

interface Props {
  formula: CarrierFormula;
}

const { formula } = Astro.props;
const isHigh = formula.confidence === "high";
---

<aside id="sources" class="card">
  <div class="px-5 py-4 border-b border-[#e2e8f0] flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-[15px] font-semibold text-[#0f172a] tracking-tight">
        {formula.label} — Source Data
      </p>
      <p class="text-[13px] text-[#64748b] mt-0.5">{formula.serviceScope}</p>
    </div>
    <span class={`badge ${isHigh ? "badge-active" : "badge-neutral"}`}>
      {formula.confidence} confidence
    </span>
  </div>

  <div class="p-5 grid gap-4">
    <dl class="grid sm:grid-cols-4 border border-[#e2e8f0] rounded-[4px] overflow-hidden">
      <div class="p-3 border-b sm:border-b-0 sm:border-r border-[#e2e8f0]">
        <dt class="section-label mb-1">Formula</dt>
        <dd class="font-mono text-[14px] font-medium text-[#0f172a]">{formula.formulaLabel}</dd>
      </div>
      <div class="p-3 border-b sm:border-b-0 sm:border-r border-[#e2e8f0]">
        <dt class="section-label mb-1">Confidence</dt>
        <dd class="text-[13px] text-[#64748b]">{formula.confidence}</dd>
      </div>
      <div class="p-3 border-b sm:border-b-0 sm:border-r border-[#e2e8f0]">
        <dt class="section-label mb-1">Verified</dt>
        <dd class="text-[13px] text-[#64748b]">{formula.sourceDate ?? "Needs source review before launch"}</dd>
      </div>
      <div class="p-3">
        <dt class="section-label mb-1">Rounding</dt>
        <dd class="text-[12px] text-[#64748b] leading-relaxed">{formula.roundingNote}</dd>
      </div>
    </dl>

    {formula.sourceUrl && (
      <a href={formula.sourceUrl} target="_blank" rel="noreferrer" class="source-link w-fit">
        View carrier source &rarr;
      </a>
    )}
  </div>

  {formula.notes && (
    <div class="border-t border-[#e2e8f0] px-5 py-3 bg-[#f8fafc]/50">
      <p class="text-[12px] text-[#64748b] leading-relaxed">{formula.notes}</p>
    </div>
  )}
</aside>
